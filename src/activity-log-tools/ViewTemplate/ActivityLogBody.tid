title: $:/plugins/linonetwo/activity-log-tools/ViewTemplate/ActivityLogBody

\procedure activity-log-columns()
[
  {
    field: "title",
    title: "<<lingo ActivityLog/Table/Key>>",
    width: 250,
    sort: "number"
  },
  {
    field: "value",
    title: "<<lingo ActivityLog/Table/Value>>",
    width: "auto",
    template: "$:/plugins/linonetwo/activity-log-tools/ViewTemplate/ActivityLogValueTemplate"
  }
]
\end

<div class="tw-gamification-activity-log-body">
<$basic-table
  filter="[<currentTiddler>indexes[]]"
  columns=<<activity-log-columns>>
  width="100%"
  height="420px"
  search="search-bar-top"
  sort="-title"
/>
</div>
