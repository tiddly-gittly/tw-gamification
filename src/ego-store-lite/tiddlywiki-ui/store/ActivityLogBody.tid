title: $:/plugins/linonetwo/ego-store-lite/tiddlywiki-ui/store/ActivityLogBody

\whitespace trim
\import [[$:/plugins/linonetwo/activity-log-tools/function/activity-log-title]]
\procedure lingo-base() $:/plugins/linonetwo/ego-store-lite/language/

<$let
  sourceTitle=<<currentTiddler>>
  refreshSeed={{{ [[$:/state/ego-store-lite/chart-refresh]get[modified]] }}}
  activityLogTitle={{{ [<sourceTitle>function[activity-log-title]] }}}
>
<div class="ego-store-lite-activity-log-panel">
  <span style="display:none;"><$text text=<<refreshSeed>>/></span>
  <h3><<lingo ActivityLog/Title>></h3>
  <$list filter="[<activityLogTitle>is[tiddler]]" variable="ignore">
    <div class="ego-store-lite-activity-log-link">
      <<lingo ActivityLog/EntryLabel>> <$link to=<<activityLogTitle>>><$text text=<<activityLogTitle>>/></$link>
    </div>
    <$set name="targetTiddler" value=<<sourceTitle>>>
      <$transclude $tiddler="$:/plugins/linonetwo/ego-store-lite/tiddlywiki-ui/visualization/gauge/LineCountsWeeks"/>
    </$set>
    <$set name="currentTiddler" value=<<activityLogTitle>>>
      <$transclude $tiddler="$:/plugins/linonetwo/activity-log-tools/ViewTemplate/ActivityLogBody"/>
    </$set>
  </$list>
  <$list filter="[<activityLogTitle>!is[tiddler]]" variable="ignore">
    <div class="tc-message-box tc-info">
      <<lingo ActivityLog/Empty>>
    </div>
  </$list>
</div>
</$let>
